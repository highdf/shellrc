# ==========fonts=========#
# BEGIN_KITTY_FONTS
font_family      family='JetBrainsMono Nerd Font' style='SemiBold Italic'
bold_font        family='JetBrainsMono Nerd Font' postscript_name=JetBrainsMonoNF-Bold
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS

font_size 22.0

# ==========color theme=========#

# light theme
# include Catppuccin-Latte.conf
# include Tokyo_Night_Day.conf

# dark theme
# include Catppuccin-Mocha.conf
# include Tokyo_Night Moon.conf

include theme.conf
# ==========color theme=========#

# 鼠标轨迹
cursor_trail 3

# 回滚配置
scrollback_lines 10000
wheel_scroll_multiplier 5.0
enable_kitty_scrollback yes

# tab配置
tab_bar_style powerline
tab_powerline_style slanted

# 性能优化
# wayland_titlebar_color background

# 自动化主题切换

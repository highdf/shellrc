# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# If you come from bash you might have to change your $PATH.
# export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH

#################################################
ZSH_THEME="powerlevel10k/powerlevel10k"

# kitty配置
export KITTY_HOME=/usr/bin/kitty
export PATH=$KITTY_HOME/bin:$PATH
alias  vimk='vim ~/.config/kitty/kitty.conf'
alias  sk='/home/luky/.config/kitty/switch.sh'

# zsh路径配置
alias vimz='vim ~/.zshrc'
alias szsh='source ~/.zshrc'

# java路径
export JAVA_HOME=/usr/local/java
export PATH=$JAVA_HOME/bin:$PATH
export CLASS_PATH=.

# neovim 路径
export NVIM_HOME=/usr/bin/nvim
export PATH=$NVIM_HOME/bin:$PATH
alias vim='nvim'
# nvim的配置文件路径
alias  vimc='vim ~/.config/nvim'
# nvim的插件路径
alias  viml='vim ~/.local/share/nvim/lazy/'
# zathura路径
alias  vimt='vim ~/.config/zathura/zathurarc'

# 中文文档
alias cman='man -M /usr/share/man/zh_CN'

# clash路径
alias clash='nohup /usr/local/clash/Clash/cfw > /home/luky/Log/nohup.out &'

# google配置
alias google='nohup google-chrome > /home/luky/Log/nohup.out &'

# yazi路径
export YAZI_HOME=/usr/local
export PATH=$YAZI_HOME/yazi:$PATH
export EDITOR='nvim'

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

# bashrc配置文件路径
alias vimb='vim ~/.bashrc'
alias sbash='source ~/.bashrc'

# 网络代理
export http_proxy='http://127.0.0.1:7890/'
export https_proxy='https://127.0.0.1:7890/'

# lazygit路径
export PATH=/usr/local/:$PATH

